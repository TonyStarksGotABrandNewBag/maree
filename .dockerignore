# Mirror .gitignore for build-context hygiene. The Dockerfile clones the
# dataset and trains the model in its own stage, so neither data/ nor
# artifacts/ needs to enter the build context.

# Python
__pycache__/
*.py[cod]
*.so
.Python
build/
*.egg-info/

# Virtual environments
.venv/
venv/

# Jupyter
.ipynb_checkpoints/
notebooks/

# Testing / lint cache
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/
.mypy_cache/

# IDE / OS
.idea/
.vscode/
.DS_Store

# Data + artifacts — produced fresh inside the trainer stage; never
# shipped from the host's working tree.
data/
artifacts/

# Results / parts (per-subprocess JSON outputs from Phase D)
results/

# Git internals
.git/
.github/

# Secrets
.env
.env.local
*.key
*.pem
