# Mirror .gitignore for build-context hygiene, but explicitly INCLUDE
# artifacts/ because the Dockerfile bakes the trained production model
# into the image.

# Python
__pycache__/
*.py[cod]
*.so
.Python
build/
*.egg-info/

# Virtual environments
.venv/
venv/

# Jupyter
.ipynb_checkpoints/
notebooks/

# Testing / lint cache
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/
.mypy_cache/

# IDE / OS
.idea/
.vscode/
.DS_Store

# Data — large, never needed inside the image (model is pre-trained)
data/

# Results / parts (per-subprocess JSON outputs from Phase D)
results/

# Git internals
.git/
.github/

# Secrets
.env
.env.local
*.key
*.pem
